{
  "expo": {
    "name": "Reglo",
    "slug": "reglo-mobile",
    "scheme": "com.tiziano.developer.reglo-mobile",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tiziano.developer.reglo-mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Reglo usa la fotocamera per acquisire foto e documenti utili alla gestione delle pratiche in autoscuola."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tiziano.developer.reglomobile",
      "versionCode": 7
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7eefa215-807f-41a7-983c-de8a494de75c"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/reglo-splash.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A2E"
        }
      ],
      "expo-web-browser",
      "expo-updates"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7eefa215-807f-41a7-983c-de8a494de75c"
      }
    },
    "owner": "sublimedapple58"
  }
}
